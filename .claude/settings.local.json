{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=\"$CLAUDE_TOOL_INPUT_file_path\"; case \"$FILE\" in *.env|*.env.*) echo \"BLOCK: Reading .env files is not allowed\"; exit 2;; esac'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)"
    ],
    "additionalDirectories": [
      "C:\\Users\\doa92\\Desktop\\Gauntlet Projects\\fsp-AirOps\\.claude"
    ]
  }
}
