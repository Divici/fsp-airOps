# =============================================================================
# Agentic Scheduler — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values for your environment.

# -----------------------------------------------------------------------------
# FSP API Configuration
# -----------------------------------------------------------------------------

# FSP authentication endpoint (API Management gateway)
FSP_API_BASE_URL=https://development-fsp.azure-api.net

# FSP API base URL (direct API)
FSP_CORE_BASE_URL=https://api-develop.flightschedulepro.com

# FSP curriculum API base URL
FSP_CURRICULUM_BASE_URL=https://curriculum-api-develop.flightschedulepro.com

# FSP subscription key — required for all FSP API requests (x-subscription-key header)
FSP_SUBSCRIPTION_KEY=your-subscription-key

# FSP environment identifier
# Values: develop
FSP_ENVIRONMENT=develop

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/fsp_airops

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

OPENAI_API_KEY=your-openai-api-key

# -----------------------------------------------------------------------------
# Inngest
# -----------------------------------------------------------------------------

INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000

